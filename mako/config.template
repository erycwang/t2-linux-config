sort=-time
layer=overlay
anchor=top-right
margin=10
padding=12,16
width=320
height=120
border-size=2
border-radius=12
default-timeout=5000

background-color=${bg}
text-color=${fg}
border-color=${accent}

font=Noto Sans 11
format=<b>%s</b>\n%b

icons=1
max-icon-size=32

[urgency=low]
border-color=${muted}
default-timeout=3000

[urgency=normal]
border-color=${accent}

[urgency=high]
border-color=${red}
default-timeout=0
background-color=${bg}
text-color=${fg}
