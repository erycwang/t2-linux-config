sort=-time
layer=overlay
anchor=top-right
margin=16,16,10,10
padding=12,16
width=320
height=120
border-size=2
border-radius=12
default-timeout=5000

background-color=#282828
text-color=#d4be98
border-color=#7daea3

font=JetBrains Mono Nerd Font 11
format=<b>%s</b>\n%b

icons=1
max-icon-size=32

[urgency=low]
border-color=#7c6f64
default-timeout=3000

[urgency=normal]
border-color=#7daea3

[urgency=high]
border-color=#ea6962
default-timeout=0
background-color=#282828
text-color=#d4be98
